# c2a-py environment configuration
# Copy this file to .env and adjust values as needed

# ── Server ─────────────────────────────────────────────────────────────────────
# Listening port (host-side; container always listens on 3010 internally)
PORT=3010

# ── Authentication ─────────────────────────────────────────────────────────────
# Comma-separated list of accepted Bearer / x-api-key tokens.
# Leave empty to disable authentication entirely.
AUTH_TOKEN=sk-change-me

# ── Upstream Cursor API ────────────────────────────────────────────────────────
CURSOR_CHAT_API=https://cursor.com/api/chat

# Model forwarded to the Cursor upstream API
CURSOR_MODEL=claude-4-5

# HTTP request timeout (seconds)
REQUEST_TIMEOUT=90

# ── Response Processing ────────────────────────────────────────────────────────
# Replace Cursor identity phrases with Claude identity in responses
SANITIZE_RESPONSE=true

# Pass tool definitions through to the upstream as-is (instead of injecting)
TOOLS_PASSTHROUGH=false

# Disable all tool injection / passthrough
TOOLS_DISABLED=false

# ── User Agent (optional) ──────────────────────────────────────────────────────
# Override the spoofed browser User-Agent sent to cursor.com.
# Defaults to a Chrome 140 UA string when left empty.
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...
